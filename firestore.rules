rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Blogs - public read/write (pages are protected by NextAuth)
    match /blogs/{document=**} {
      allow read, write: if true;
    }

    // Comments - public read/write (pages are protected by NextAuth)
    match /comments/{document=**} {
      allow read, write: if true;
    }

    // Analytics - public read/write (for tracking)
    match /analytics/{document=**} {
      allow read, write: if true;
    }

    // Settings - public read/write (pages are protected by NextAuth)
    match /settings/{document=**} {
      allow read, write: if true;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
